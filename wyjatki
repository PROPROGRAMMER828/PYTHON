def pobierz_statystyki_per_aktywnosc(self):
    slownik = {}

    for trening in self.treningi:
        if trening.typ_aktywnosci in slownik:
            slownik[trening.typ_aktywnosci] += trening.dystans_km
        else:
            slownik[trening.typ_aktywnosci] = trening.dystans_km

    return slownik


# Schemat:

def pobierz_statystyki_sumy(self):
    slownik = {}

    for obiekt in self.lista:
        if obiekt.klucz in slownik:
            slownik[obiekt.klucz] += obiekt.wartosc
        else:
            slownik[obiekt.klucz] = obiekt.wartosc

    return slownik


