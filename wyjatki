class BatteryLog:
    def __init__(self, log_id, id_baterii, temperatura_c):
        self.log_id = log_id
        self.id_baterii = id_baterii
        self.temperatura_c = temperatura_c

        if temperatura_c > 60.0:
            self.status = "PRZEGRZANA"
        else:
