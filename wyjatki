# 1. ŚREDNIA Z DWÓCH PÓL NARAZ
# Fragment polecenia:
# "oblicza średnią temperaturę i wilgotność"
# "zwraca średnią temperaturę oraz średnią wilgotność"
# "średni dystans i średni czas"
# ============================================================
#
# Użyj, gdy trzeba policzyć dwie średnie jednocześnie.


def oblicz_srednie(self, miasto):
    suma_temperatur = 0
    suma_wilgotnosci = 0
    licznik = 0

    for odczyt in self.odczyty:
        if odczyt.miasto == miasto:
            suma_temperatur += odczyt.temperatura
            suma_wilgotnosci += odczyt.wilgotnosc
            licznik += 1

    return suma_temperatur / licznik, suma_wilgotnosci / licznik


