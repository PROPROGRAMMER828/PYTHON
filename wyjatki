def aktualizuj_cos(self, id, nowa_wartosc):
    for obiekt in self.lista:
        if obiekt.id == id:
            obiekt.pole = nowa_wartosc

            if nowa_wartosc > 0:
                obiekt.status = "STATUS_1"
            else:
