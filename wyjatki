def wypozycz_bron(self, nr_ser, nazwisko):
    for bron in self.bronie:
        if bron.nr_ser == nr_ser:

            if bron.wypozyczona:
                return False

            bron.wypozyczona = True
            bron.wypozyczyl = nazwisko

            return True

    return False


