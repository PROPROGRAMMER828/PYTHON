def pobierz_oceny_filmow(self):
    slownik = {}

    for film in self.filmy:
        slownik[film.film_id] = film.ocena

    return slownik


# Schemat:

def pobierz_slownik(self):
    slownik = {}

    for obiekt in self.lista:
