def usun_film(self, film_id):
    for film in self.filmy:
        if film.film_id == film_id:
            self.filmy.remove(film)
            return True

    return False


# Schemat:

def usun_cos(self, id):
    for obiekt in self.lista:
        if obiekt.id == id:
            self.lista.remove(obiekt)
            return True

    return False


