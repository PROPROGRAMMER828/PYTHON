# ============================================================
#
# Użyj, gdy trzeba policzyć średnią jednego pola liczbowego.


def oblicz_srednia_ocene(self, gatunek):
    suma = 0
    licznik = 0

    for film in self.filmy:
        if film.gatunek == gatunek:
            suma += film.ocena
            licznik += 1

    return suma / licznik


# Schemat:

def oblicz_srednia(self, parametr):
    suma = 0
    licznik = 0

    for obiekt in self.lista:
        if obiekt.pole == parametr:
            suma += obiekt.pole_liczbowe
            licznik += 1

