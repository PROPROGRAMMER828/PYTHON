# "zwraca słownik z liczbą obiektów każdego typu"
# "liczba zgłoszeń według statusu"
# ============================================================
#
# Użyj, gdy trzeba policzyć, ile razy występuje dana kategoria.


def pobierz_statystyki_gatunkow(self):
    slownik = {}

    for film in self.filmy:
        if film.gatunek in slownik:
            slownik[film.gatunek] += 1
        else:
            slownik[film.gatunek] = 1

    return slownik


# Schemat:

def pobierz_statystyki(self):
    slownik = {}

    for obiekt in self.lista:
        if obiekt.pole in slownik:
            slownik[obiekt.pole] += 1
        else:
            slownik[obiekt.pole] = 1

    return slownik


