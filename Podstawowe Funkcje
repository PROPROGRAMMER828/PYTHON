def policz_filmy_gatunku(self, gatunek):
    licznik = 0

    for film in self.filmy:
        if film.gatunek == gatunek:
            licznik += 1

    return licznik


# Schemat:

def policz_cos(self, parametr):
    licznik = 0

    for obiekt in self.lista:
        if obiekt.pole == parametr:
